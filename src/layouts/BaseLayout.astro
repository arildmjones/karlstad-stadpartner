---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Karlstad Städpartner",
  description = "Din städpartner i Värmland"
} = Astro.props;

---
<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f7f7f5;
        --surface: #ffffff;
        --text: #1f2937;
        --muted: #6b7280;
        --border: #e5e7eb;
        --accent: #1d4ed8;
        --accent-strong: #1e40af;
        --max: 1100px;
      }
      * { box-sizing: border-box; }
      html { font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
      body {
        margin: 0;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
      }
      a { color: inherit; }
      .container {
        width: min(calc(100% - 2rem), var(--max));
        margin: 0 auto;
      }
      header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index:5;
      }
      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .brand {
        font-weight: 700;
        letter-spacing: 0.02em;
        text-decoration: none;
      }
      .links {
        flex-wrap: wrap;
      }
      .links a {
           font-weight: 600;
           font-size: 16px;
        text-decoration: none;
        color: var(--muted);
      }
      .hero {
        padding: 5rem 0 3rem;
        display: grid;
        gap: 2rem;
        align-items: center;
        grid-template-columns: 1.2fr 0.8fr;
      }
      .hero-card,
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 1.5rem;
      } 
      .eyebrow {
        color: var(--accent);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.8rem;
      }
      h1, h2, h3 { line-height: 1.15; margin: 0 0 1rem; }
      h1 { font-size: clamp(2.25rem, 5vw, 4rem); }
      h2 { font-size: clamp(1.6rem, 3vw, 2.3rem); }
      p { margin: 0 0 1rem; }
      .muted { color: var(--muted); }
      .cta-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0.8rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        border: 1px solid var(--border);
        background: var(--surface);
      }
      .button.primary {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }
      .button.primary:hover { background: var(--accent-strong); }
      section { padding: 2rem 0; }
      .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
      .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      ul.clean {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.75rem;
      }
      label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.35rem;
      }
      input, textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.9rem 1rem;
        font: inherit;
        background: #fff;
      }
      textarea { min-height: 150px; resize: vertical; }
      form { display: grid; gap: 1rem; }
      footer {
        padding: 3rem 0;
        color: var(--muted);
      }
      .small { font-size: 0.95rem; }
      @media (max-width: 820px) {
        .hero,
        .grid-2,
        .grid-3 {
          grid-template-columns: 1fr;
        }
        header { position: static; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container nav py-6">
        <a class="brand" href="#top"><img src="/public/logo.svg" /></a>
        <nav class="links flex gap-8 fw-bold" aria-label="Huvudnavigering">
          <a href="#tjanster">Tjänster</a> 
          <a href="#om-oss">Om oss</a>
          <a href="#kontakt">Kontakt</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container small">
        © {new Date().getFullYear()} Företagsnamn · Enkel Astro + Netlify-sajt
      </div>
    </footer>
  </body>
</html>
