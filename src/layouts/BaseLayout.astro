---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Karlstad Städpartner",
  description = "Din städpartner i Värmland"
} = Astro.props;
---

<!doctype html>
<html lang="sv" class="font-sans scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="m-0 bg-[#f7f7f5] text-slate-800 leading-relaxed">
    <header class="sticky top-0 z-[5] border-b border-slate-200 bg-white max-[820px]:static">
      <div class="mx-auto flex w-[min(calc(100%-2rem),1100px)] items-center justify-between gap-4 py-6">
        <a class="font-bold tracking-[0.02em] no-underline" href="#top">
          <img src="/logo.svg" class="h-8 md:h-14 w-auto" alt="Karlstad Städpartner" />
        </a>

        <nav
          class="hidden gap-8 md:flex md:flex-wrap"
          aria-label="Huvudnavigering"
        >
          <a class="text-base font-semibold text-slate-500 no-underline" href="#tjanster">
            Tjänster
          </a>
          <a class="text-base font-semibold text-slate-500 no-underline" href="#om-oss">
            Om oss
          </a>
          <a class="text-base font-semibold text-slate-500 no-underline" href="#kontakt">
            Kontakt
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="py-12 text-slate-500">
      <div class="mx-auto w-[min(calc(100%-2rem),1100px)] text-[0.95rem]">
        © {new Date().getFullYear()} Karlstad Städpartner AB. Alla rättigheter förbehållna.
        <br />
      </div>
    </footer>
  </body>
</html>