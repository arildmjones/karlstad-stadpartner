---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title = "Karlstad Städpartner",
  description = "Din städpartner i Värmland",
  canonical = "https://www.karlstadstäd.se",
  image = "https://www.karlstadstäd.se/og-image.jpg",
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Karlstad Städpartner",
  image,
  url: canonical,
  telephone: "070-123 45 67",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Karlstad",
    addressCountry: "SE",
  },
};
---

<!doctype html>
<html lang="sv" class="scroll-smooth font-sans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content="Karlstad Städpartner" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="theme-color" content="#1D2B36" />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>

  <body class="m-0 bg-[#f7f7f5] leading-relaxed text-slate-800">
    <header
      class="sticky top-0 z-[5] border-b border-slate-200 bg-white max-[820px]:static"
    >
      <div
        class="mx-auto flex w-[min(calc(100%-2rem),1100px)] items-center justify-between gap-4 py-6"
      >
        <a class="font-bold tracking-[0.02em] no-underline" href="#top">
          <img
            src="/logo.svg"
            class="h-8 w-auto md:h-14"
            alt="Karlstad Städpartner"
          />
        </a>

        <nav
          class="hidden gap-8 md:flex md:flex-wrap"
          aria-label="Huvudnavigering"
        >
          <a
            class="text-base font-semibold text-slate-500 no-underline"
            href="#tjanster"
          >
            Tjänster
          </a>
          <a
            class="text-base font-semibold text-slate-500 no-underline"
            href="#om-oss"
          >
            Om oss
          </a>
          <a
            class="text-base font-semibold text-slate-500 no-underline"
            href="#kontakt"
          >
            Kontakt
          </a>
        </nav>
      </div>
    </header>

    <main id="top">
      <slot />
    </main>

    <footer class="py-12 text-slate-500">
      <div
        class="mx-auto flex w-[min(calc(100%-2rem),1100px)] gap-4 text-[0.95rem]"
      >
        <div class="flex flex-col gap-2">
          <span
            >© {new Date().getFullYear()} Karlstad Städpartner AB. Alla rättigheter
            förbehållna.</span
          >
          <span class="font-bold">orgnummer: xxx</span>
        </div>
        <img
          src="/logo.svg"
          class="ml-auto h-8 w-auto md:h-20"
          alt="Karlstad Städpartner"
        />
      </div>
    </footer>
  </body>
</html>
