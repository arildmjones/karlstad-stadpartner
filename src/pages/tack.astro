---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Tack | Företagsnamn" description="Tack för ditt meddelande.">
  <section>
    <div class="container">
      <div class="card" style="max-width: 680px; margin: 3rem auto; text-align: center;">
        <h1 style="font-size: 2.2rem;">Tack!</h1>
        <p class="muted">Vi har tagit emot ditt meddelande och återkommer så snart vi kan.</p>
        <a class="button primary" href="/">Tillbaka till startsidan</a>
      </div>
    </div>
  </section>
</BaseLayout>
